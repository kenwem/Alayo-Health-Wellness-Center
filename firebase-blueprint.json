{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration and assets",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "URL of the website logo" },
        "heroBgUrl": { "type": "string", "description": "URL of the hero section background" },
        "aboutBgUrl": { "type": "string", "description": "URL of the about page background" },
        "servicesBgUrl": { "type": "string", "description": "URL of the services page background" },
        "ceoPhotoUrl": { "type": "string", "description": "URL of the CEO/Chief Consultant photo" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Herbal products and healing tools",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "salePrice": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "shortDescription": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Editorial": {
      "title": "Editorial",
      "description": "Health education articles and research",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["Published", "Draft"] }
      },
      "required": ["title", "author", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "User consultation bookings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"] }
      },
      "required": ["name", "email", "service", "date", "time"]
    },
    "Order": {
      "title": "Order",
      "description": "Product purchase records",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "items", "total"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "User": {
      "title": "User",
      "description": "User profiles and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "settings/site": {
      "schema": { "$ref": "SiteSettings" },
      "description": "Global site settings"
    },
    "products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Product inventory"
    },
    "editorial/{articleId}": {
      "schema": { "$ref": "Editorial" },
      "description": "Editorial articles"
    },
    "appointments/{appointmentId}": {
      "schema": { "$ref": "Appointment" },
      "description": "User appointments"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Customer orders"
    },
    "messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Contact messages"
    },
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    }
  }
}
