{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration and assets",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "URL of the website logo" },
        "heroBgUrl": { "type": "string", "description": "URL of the hero section background" },
        "heroTitle": { "type": "string", "description": "Main title on the home page" },
        "heroSubtitle": { "type": "string", "description": "Subtitle on the home page" },
        "aboutBgUrl": { "type": "string", "description": "URL of the about page background" },
        "aboutFacts": { "type": "array", "items": { "type": "object" }, "description": "Quick facts for the about page" },
        "servicesBgUrl": { "type": "string", "description": "URL of the services page background" },
        "blogBgUrl": { "type": "string", "description": "URL of the editorial page background" },
        "ceoPhotoUrl": { "type": "string", "description": "URL of the CEO/Chief Consultant photo" },
        "copyrightText": { "type": "string", "description": "Copyright text in footer" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Herbal products and healing tools",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "salePrice": { "type": "string" },
        "stock": { "type": "number", "description": "Stock quantity (optional)" },
        "imageUrl": { "type": "string" },
        "shortDescription": { "type": "string" },
        "position": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "Service": {
      "title": "Service",
      "description": "Health and wellness services",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "image": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "position": { "type": "number" }
      },
      "required": ["title", "description", "position"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client and patient reviews",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "location": { "type": "string" },
        "position": { "type": "number" }
      },
      "required": ["text", "author", "position"]
    },
    "Book": {
      "title": "Book",
      "description": "Naturopathic books and research extracts",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "price": { "type": "string" },
        "status": { "type": "string" },
        "coverImage": { "type": "string" },
        "preface": { "type": "string" },
        "position": { "type": "number" }
      },
      "required": ["title", "author", "position"]
    },
    "Editorial": {
      "title": "Editorial",
      "description": "Health education articles and research",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["Published", "Draft"] }
      },
      "required": ["title", "author", "status"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "User consultation bookings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"] }
      },
      "required": ["name", "email", "service", "date", "time"]
    },
    "Order": {
      "title": "Order",
      "description": "Product purchase records",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "items", "total"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "User": {
      "title": "User",
      "description": "User profiles and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "sites/{siteId}/settings/site": {
      "schema": { "$ref": "SiteSettings" },
      "description": "Global site settings"
    },
    "sites/{siteId}/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Product inventory"
    },
    "sites/{siteId}/editorial/{articleId}": {
      "schema": { "$ref": "Editorial" },
      "description": "Editorial articles"
    },
    "sites/{siteId}/services/{serviceId}": {
      "schema": { "$ref": "Service" },
      "description": "Services content"
    },
    "sites/{siteId}/testimonials/{testimonialId}": {
      "schema": { "$ref": "Testimonial" },
      "description": "Client testimonials"
    },
    "sites/{siteId}/books/{bookId}": {
      "schema": { "$ref": "Book" },
      "description": "Books and research extracts"
    },
    "sites/{siteId}/{collection}/{docId}/comments/{commentId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userEmail": { "type": "string" },
          "text": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["pending", "approved"] }
        }
      },
      "description": "Comments on any content"
    },
    "sites/{siteId}/{collection}/{docId}/comments/{commentId}/replies/{replyId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userEmail": { "type": "string" },
          "text": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["pending", "approved"] }
        }
      },
      "description": "Replies to comments"
    },
    "sites/{siteId}/appointments/{appointmentId}": {
      "schema": { "$ref": "Appointment" },
      "description": "User appointments"
    },
    "sites/{siteId}/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Customer orders"
    },
    "sites/{siteId}/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Contact messages"
    },
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    }
  }
}
